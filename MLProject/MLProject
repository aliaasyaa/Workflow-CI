name: stroke_classification

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 0
      random_state:
        type: int
        default: 42
      class_weight:
        type: str
        default: "balanced"
    command: >
      python modelling.py
      --n_estimators {n_estimators}
      --max_depth {max_depth}
      --random_state {random_state}
      --class_weight {class_weight}
